# =============================================================================
# SentrixScan — environment variables
# =============================================================================
# Copy this file to `.env.local` and fill in the values you need.
# Anything beginning with NEXT_PUBLIC_ is exposed to the browser — never put
# secrets there. Server-only secrets live in the non-prefixed variables below.
#
# None of these values are required for the app to boot; every read has a
# sensible production fallback. Override only when you need to point at a
# different chain node or enable an optional integration (Sentry, analytics).
# =============================================================================


# ── Chain endpoints (public) ────────────────────────────────────────────────
# Mainnet
NEXT_PUBLIC_MAINNET_CHAIN_ID=7119
NEXT_PUBLIC_MAINNET_RPC=https://sentrix-rpc.sentriscloud.com/rpc
NEXT_PUBLIC_MAINNET_API=https://sentrix-api.sentriscloud.com

# Testnet
NEXT_PUBLIC_TESTNET_CHAIN_ID=7120
NEXT_PUBLIC_TESTNET_RPC=https://testnet-rpc.sentriscloud.com/rpc
NEXT_PUBLIC_TESTNET_API=https://testnet-api.sentriscloud.com

# Which network users land on by default (mainnet | testnet).
NEXT_PUBLIC_DEFAULT_NETWORK=mainnet


# ── Site / SEO ──────────────────────────────────────────────────────────────
# Canonical origin used in <link rel="canonical">, robots.txt, sitemap.xml,
# OpenGraph tags, etc. Set this to the deployed URL.
NEXT_PUBLIC_SITE_URL=https://sentrixscan.sentriscloud.com


# ── Sentry error tracking (optional) ────────────────────────────────────────
# Create a Next.js project at https://sentry.io and paste the DSN here.
# Leave empty to disable Sentry entirely (no outbound network traffic).
NEXT_PUBLIC_SENTRY_DSN=

# Server-side only. Used by @sentry/nextjs at build time to upload source
# maps so stack traces deminify in the Sentry UI. NEVER put this in a
# NEXT_PUBLIC_ variable — it grants release-publish access to the org.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=


# ── Dev-time toggles (optional) ─────────────────────────────────────────────
# Tag every Sentry event with this environment label. Vercel auto-populates
# NEXT_PUBLIC_VERCEL_ENV, so you only need to set this for non-Vercel hosts.
# NEXT_PUBLIC_VERCEL_ENV=production


# =============================================================================
# NEVER add to this file:
#   - Private keys / mnemonics / seed phrases
#   - API keys that grant write access to anything
#   - Database connection strings with credentials
#   - Cookies, session secrets, JWT signing keys
#
# If a value must be secret, put it in `.env.local` (gitignored). The public
# repo should only ever carry this template.
# =============================================================================
